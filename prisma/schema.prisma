generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTHENTICATION (Better-Auth compatible)
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  role          Role      @default(ADMIN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

// ============================================
// PORTFOLIO CONTENT
// ============================================

model Project {
  id           String          @id @default(cuid())
  title        String
  subtitle     String
  description  String          @db.Text
  image        String
  technologies String[]
  category     ProjectCategory
  websiteUrl   String?
  hasLiveUrl   Boolean         @default(false)
  order        Int             @default(0)
  isPublished  Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

enum ProjectCategory {
  web
  mobile
  desktop
}

model Technology {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScrollLogo {
  id        String   @id @default(cuid())
  src       String
  alt       String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(cuid())
  name      String
  url       String
  icon      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HeroSection {
  id                String   @id @default(cuid())
  locale            String   @unique
  greeting          String
  name              String
  title             String
  description       String   @db.Text
  cvUrl             String?
  heroImage         String?
  projectsCount     Int      @default(5)
  experienceYears   Int      @default(3)
  technologiesCount Int      @default(15)
  // CTA Labels
  ctaProjects       String   @default("Voir mes projets")
  ctaCv             String   @default("Télécharger CV")
  // Stats Labels
  statsProjects     String   @default("Projets")
  statsExperience   String   @default("Années d'expérience")
  statsTechnologies String   @default("Technologies")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AboutSection {
  id                  String   @id @default(cuid())
  locale              String   @unique
  badge               String
  title               String
  description         String   @db.Text
  bio                 String   @db.Text
  profileImage        String?
  certificationsTitle String
  stackTitle          String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  certifications Certification[]
}

model Certification {
  id             String        @id @default(cuid())
  key            String
  title          String
  locale         String
  aboutSectionId String?
  aboutSection   AboutSection? @relation(fields: [aboutSectionId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([key, locale])
}

model Service {
  id          String   @id @default(cuid())
  key         String
  locale      String
  title       String
  description String   @db.Text
  badgeText   String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, locale])
}

model ContactSection {
  id             String   @id @default(cuid())
  locale         String   @unique
  badge          String
  title          String
  description    String   @db.Text
  socialsTitle   String
  techLogosTitle String   @default("Technologies que j'utilise au quotidien")
  isFormEnabled  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  benefits  ContactBenefit[]
  stats     ContactStat[]
  techLogos ContactTechLogo[]
}

model ContactBenefit {
  id               String          @id @default(cuid())
  text             String
  order            Int             @default(0)
  contactSectionId String?
  contactSection   ContactSection? @relation(fields: [contactSectionId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model ContactStat {
  id               String          @id @default(cuid())
  value            String
  label            String
  order            Int             @default(0)
  contactSectionId String?
  contactSection   ContactSection? @relation(fields: [contactSectionId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model ContactTechLogo {
  id               String          @id @default(cuid())
  src              String
  alt              String
  order            Int             @default(0)
  contactSectionId String?
  contactSection   ContactSection? @relation(fields: [contactSectionId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model SiteSettings {
  id              String   @id @default(cuid())
  siteName        String   @default("Yann Clain Portfolio")
  siteUrl         String
  logoUrl         String?
  faviconUrl      String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
